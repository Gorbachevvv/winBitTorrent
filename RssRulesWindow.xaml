<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinBitTorrent.RssRulesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RSS downloader rules">
    <Grid Padding="18" ColumnSpacing="14">
        <Grid.ColumnDefinitions><ColumnDefinition Width="245" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><TextBlock x:Uid="RssRulesListTitle" Margin="14,12,10,8" FontSize="18" FontWeight="SemiBold" Text="Rules" /><ListView x:Name="RulesList" Grid.Row="1" SelectionChanged="RulesList_SelectionChanged" /><StackPanel Grid.Row="2" Margin="10" Orientation="Horizontal" Spacing="8"><Button x:Uid="CommonNew" Content="New" Click="New_Click" /><Button x:Uid="CommonDelete" Content="Delete" Click="Delete_Click" /></StackPanel></Grid></Border>
        <ScrollViewer Grid.Column="1"><StackPanel Spacing="12">
            <TextBlock x:Uid="RssRuleTitle" Style="{StaticResource TitleTextBlockStyle}" Text="Automatic downloader rule" />
            <InfoBar x:Name="MessageBar" IsClosable="True" IsOpen="False" />
            <TextBox x:Uid="RssRuleName" x:Name="RuleNameBox" Header="Rule name" />
            <ToggleSwitch x:Uid="RssRuleEnabled" x:Name="EnabledSwitch" Header="Enabled" IsOn="True" />
            <TextBox x:Uid="RssRuleMustContain" x:Name="MustContainBox" Header="Must contain" PlaceholderText="Words separated by |" />
            <TextBox x:Uid="RssRuleMustNotContain" x:Name="MustNotContainBox" Header="Must not contain" />
            <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBox x:Uid="RssRuleEpisode" x:Name="EpisodeBox" Header="Episode filter" PlaceholderText="1x01-; S01E01-" /><TextBox x:Uid="RssRuleCategory" x:Name="CategoryBox" Grid.Column="1" Header="Assign category" /></Grid>
            <TextBox x:Uid="RssRuleFeeds" x:Name="FeedsBox" Header="Apply rule to feeds" PlaceholderText="One feed path per line; leave empty for all" AcceptsReturn="True" Height="76" />
            <TextBox x:Uid="RssRuleSavePath" x:Name="SavePathBox" Header="Save to a different directory" />
            <StackPanel Orientation="Horizontal" Spacing="22"><CheckBox x:Uid="RssRuleRegex" x:Name="RegexBox" Content="Use regular expressions" /><CheckBox x:Uid="RssRuleSmartFilter" x:Name="SmartFilterBox" Content="Use smart episode filter" IsChecked="True" /><CheckBox x:Uid="RssRulePaused" x:Name="PausedBox" Content="Add torrents stopped" /></StackPanel>
        </StackPanel></ScrollViewer>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8"><Button x:Uid="CommonClose" Content="Close" Click="Close_Click" /><Button x:Uid="RssRuleSave" Content="Save rule" Style="{StaticResource AccentButtonStyle}" Click="Save_Click" /></StackPanel>
    </Grid>
</Window>
