<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinBitTorrent.Views.RssView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="4">
        <Grid.RowDefinitions><RowDefinition Height="46" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <CommandBar Background="Transparent" DefaultLabelPosition="Right">
            <AppBarButton x:Uid="RssNewFeed" Icon="Add" Label="New feed" Click="AddFeed_Click" />
            <AppBarButton x:Uid="RssNewFolder" Icon="NewFolder" Label="New folder" Click="AddFolder_Click" />
            <AppBarButton x:Uid="RssRefresh" Icon="Refresh" Label="Refresh" Command="{Binding RefreshSelectedCommand}" />
            <AppBarButton x:Uid="RssRemove" Icon="Delete" Label="Remove" Command="{Binding RemoveSelectedCommand}" />
            <AppBarSeparator />
            <AppBarButton x:Uid="RssRules" Icon="Setting" Label="RSS rules" Click="Rules_Click" />
        </CommandBar>
        <Grid Grid.Row="1" ColumnSpacing="4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="230" /><ColumnDefinition Width="320" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock x:Uid="RssFeeds" Margin="12,10,8,6" FontWeight="SemiBold" Text="Feeds" /><ListView Grid.Row="1" ItemsSource="{Binding Feeds}" SelectedItem="{Binding SelectedFeed, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="6,4"><TextBlock TextTrimming="CharacterEllipsis" Text="{Binding Title}" /><TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" Text="{Binding Url}" /></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></Grid>
            </Border>
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock x:Uid="RssArticles" Margin="12,10,8,6" FontWeight="SemiBold" Text="Articles" /><ListView Grid.Row="1" ItemsSource="{Binding Articles}" SelectedItem="{Binding SelectedArticle, Mode=TwoWay}" SelectionChanged="ArticleList_SelectionChanged"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="6,5" Spacing="2"><TextBlock MaxLines="2" TextWrapping="Wrap" Text="{Binding Title}" /><TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding PublishedText}" /></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></Grid>
            </Border>
            <Border Grid.Column="2" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid Padding="12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock MaxLines="2" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding SelectedArticle.Title}" /><Button x:Uid="RssOpenLink" Grid.Column="1" Margin="8,0,0,0" Content="Open link" Click="OpenArticle_Click" /></Grid><ScrollViewer Grid.Row="1" Padding="14,6"><TextBlock x:Name="ArticleBody" IsTextSelectionEnabled="True" TextWrapping="Wrap" /></ScrollViewer></Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
