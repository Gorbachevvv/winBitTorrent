<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinBitTorrent.Views.TransfersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinBitTorrent.Controls"
    xmlns:viewModels="using:WinBitTorrent.ViewModels"
    xmlns:tv="using:WinUI.TableView">

    <UserControl.Resources>
        <!-- Preserve TableView's native cell template (it owns column geometry),
             but neutralize only its per-cell hover/selection/focus brushes. -->
        <SolidColorBrush x:Key="TableViewCellBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="TableViewCellBackgroundSelected" Color="Transparent" />
        <SolidColorBrush x:Key="TableViewCellSelectionBrush" Color="Transparent" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="150" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="0,0,4,0" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="4,6" Spacing="2">
                    <Expander x:Uid="StatusFilter" Header="Status" IsExpanded="True">
                        <ListView
                            x:Name="StatusList"
                            Style="{StaticResource SidebarListViewStyle}"
                            ItemsSource="{Binding StatusFilters}"
                            SelectionChanged="FilterList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon FontSize="13" Glyph="{Binding Glyph}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Title}" />
                                        <TextBlock Grid.Column="2" Margin="8,0,2,0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Count}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                    <Expander x:Uid="CategoriesFilter" Header="Categories" IsExpanded="True">
                        <ListView x:Name="CategoriesList" Style="{StaticResource SidebarListViewStyle}" ItemsSource="{Binding CategoryFilters}" SelectionChanged="FilterList_SelectionChanged">
                            <ListView.ContextFlyout><MenuFlyout><MenuFlyoutItem x:Uid="NewCategory" Text="New category…" Click="CreateCategory_Click" /><MenuFlyoutItem x:Uid="EditCategory" Text="Edit category…" Click="EditCategory_Click" /><MenuFlyoutItem x:Uid="DeleteCategory" Text="Delete category" Click="DeleteCategory_Click" /></MenuFlyout></ListView.ContextFlyout>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6,3">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <FontIcon FontSize="13" Glyph="{Binding Glyph}" />
                                        <TextBlock Grid.Column="1" TextTrimming="CharacterEllipsis" Text="{Binding Title}" />
                                        <TextBlock Grid.Column="2" Margin="8,0,2,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Count}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                    <Expander x:Uid="TagsFilter" Header="Tags" IsExpanded="True">
                        <ListView x:Name="TagsList" Style="{StaticResource SidebarListViewStyle}" ItemsSource="{Binding TagFilters}" SelectionChanged="FilterList_SelectionChanged">
                            <ListView.ContextFlyout><MenuFlyout><MenuFlyoutItem x:Uid="CreateTags" Text="Create tags…" Click="CreateTags_Click" /><MenuFlyoutItem x:Uid="DeleteTag" Text="Delete tag" Click="DeleteTag_Click" /></MenuFlyout></ListView.ContextFlyout>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6,3">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <FontIcon FontSize="13" Glyph="{Binding Glyph}" />
                                        <TextBlock Grid.Column="1" TextTrimming="CharacterEllipsis" Text="{Binding Title}" />
                                        <TextBlock Grid.Column="2" Margin="8,0,2,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Count}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                    <Expander x:Uid="TrackersFilter" Header="Trackers" IsExpanded="True">
                        <ListView Style="{StaticResource SidebarListViewStyle}" ItemsSource="{Binding TrackerFilters}" SelectionChanged="FilterList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6,3">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <FontIcon FontSize="13" Glyph="{Binding Glyph}" />
                                        <TextBlock Grid.Column="1" TextTrimming="CharacterEllipsis" Text="{Binding Title}" />
                                        <TextBlock Grid.Column="2" Margin="8,0,2,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Count}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Thumb Grid.Column="1" Background="Transparent" DragDelta="SidebarSplitter_DragDelta" />

        <Grid x:Name="ContentGrid" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="180" />
                <RowDefinition Height="6" />
                <RowDefinition Height="260" MinHeight="140" />
            </Grid.RowDefinitions>

            <tv:TableView
                x:Name="TorrentTable"
                Grid.Row="0"
                AutoGenerateColumns="False"
                CanResizeColumns="True"
                CanReorderColumns="True"
                CanSortColumns="True"
                IsReadOnly="True"
                AlternateRowBackground="{ThemeResource SubtleFillColorSecondaryBrush}"
                HeadersVisibility="Columns"
                SelectionMode="Extended"
                SelectionUnit="Row"
                ItemsSource="{Binding Torrents}"
                ColumnReordered="TorrentTable_ColumnReordered"
                RowContextFlyoutOpening="TorrentTable_RowContextFlyoutOpening"
                SelectionChanged="TorrentTable_SelectionChanged">
                <tv:TableView.RowContextFlyout>
                    <MenuFlyout Opening="TorrentContextMenu_Opening">
                        <MenuFlyoutItem x:Name="StartMenuItem" x:Uid="Start" Text="Start" Click="Start_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE768;" Foreground="#16A34A" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="StopMenuItem" x:Uid="Stop" Text="Stop" Click="Stop_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE71A;" Foreground="#DC2626" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="ForceStart" Text="Force start" Click="ForceStart_Click">
                            <MenuFlyoutItem.Icon><FontIcon x:Name="ForceStartCheckIcon" Glyph="&#xE739;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="SetLocation" Text="Set location…" Click="SetLocation_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8DE;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="RenameTorrent" Text="Rename…" Click="Rename_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem x:Name="CategorySubmenu" x:Uid="CategoryMenu" Text="Category">
                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE8EC;" Foreground="#D97706" /></MenuFlyoutSubItem.Icon>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem x:Uid="TagsMenu" Text="Tags">
                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE8EC;" Foreground="#9333EA" /></MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem x:Uid="AddTags" Text="Add tags…" Tag="add" Click="Tags_Click" />
                            <MenuFlyoutItem x:Uid="RemoveTags" Text="Remove tags…" Tag="remove" Click="Tags_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutSubItem x:Uid="QueueMenu" Text="Queue">
                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xEA37;" Foreground="#64748B" /></MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem x:Uid="MoveTop" Text="Move to top" Click="QueueTop_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="MoveUp" Text="Move up" Click="MoveUp_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="MoveDown" Text="Move down" Click="MoveDown_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="MoveBottom" Text="Move to bottom" Click="QueueBottom_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem x:Uid="SequentialDownload" Text="Download in sequential order" Click="Sequential_Click">
                            <MenuFlyoutItem.Icon><FontIcon x:Name="SequentialCheckIcon" Glyph="&#xE739;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="FirstLastPriority" Text="Download first and last pieces first" Click="FirstLast_Click">
                            <MenuFlyoutItem.Icon><FontIcon x:Name="FirstLastCheckIcon" Glyph="&#xE739;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="SuperSeeding" Text="Super seeding mode" Click="SuperSeeding_Click">
                            <MenuFlyoutItem.Icon><FontIcon x:Name="SuperSeedingCheckIcon" Glyph="&#xE739;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem x:Uid="LimitRate" Text="Limit rate">
                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE9E9;" Foreground="#0D9488" /></MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem x:Uid="TransferLimits" Text="Download and upload limits…" Click="Limits_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE9E9;" Foreground="#0D9488" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ShareLimits" Text="Share ratio and seeding time…" Click="ShareLimits_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE9E9;" Foreground="#0D9488" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem x:Uid="TrackersWebSeeds" Text="Trackers and web seeds">
                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE774;" Foreground="#2563EB" /></MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem x:Uid="AddTrackers" Text="Add trackers…" Click="AddTrackers_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE774;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="AddWebSeeds" Text="Add web seeds…" Click="AddWebSeeds_Click">
                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE71B;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="ForceRecheck" Text="Force recheck" Click="ForceRecheck_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72C;" Foreground="#2563EB" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="Reannounce" Text="Reannounce" Click="Reannounce_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE789;" Foreground="#D97706" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="PreviewMenuItem" x:Uid="PreviewAvailableFile" Text="Preview first available file" Click="PreviewFile_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B3;" Foreground="#0D9488" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="OpenDestinationMenuItem" x:Uid="OpenDestination" Text="Open destination folder" Click="OpenDestination_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" Foreground="#D97706" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem x:Uid="CopyMenu" Text="Copy">
                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE8C8;" Foreground="#64748B" /></MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem x:Uid="CopyName" Text="Name" Tag="name" Click="CopyInfo_Click" />
                            <MenuFlyoutItem x:Uid="CopyHashV1" Text="Info hash v1" Tag="hashv1" Click="CopyInfo_Click" />
                            <MenuFlyoutItem x:Uid="CopyHashV2" Text="Info hash v2" Tag="hashv2" Click="CopyInfo_Click" />
                            <MenuFlyoutItem x:Uid="CopyMagnet" Text="Magnet link" Tag="magnet" Click="CopyInfo_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem x:Uid="ExportTorrent" Text="Export .torrent…" Click="Export_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74E;" Foreground="#64748B" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="ChooseColumns" Text="Choose columns…" Click="ChooseColumns_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;" Foreground="#64748B" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="Delete" Text="Delete…" Click="DeleteSelected_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" Foreground="#DC2626" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </tv:TableView.RowContextFlyout>
                <tv:TableView.Columns>
                    <tv:TableViewTemplateColumn Header="" Width="40" MinWidth="34" CanResize="False">
                        <tv:TableViewTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Glyph="{Binding StatusGlyph}"
                                    Foreground="{Binding StatusBrush}"
                                    ToolTipService.ToolTip="{Binding Status}" />
                            </DataTemplate>
                        </tv:TableViewTemplateColumn.CellTemplate>
                    </tv:TableViewTemplateColumn>
                    <tv:TableViewTextColumn x:Uid="ColumnName" Header="Name" Width="2*" MinWidth="180" Binding="{Binding Name}" />
                    <tv:TableViewTextColumn x:Uid="ColumnSize" Header="Size" Width="90" Binding="{Binding Size}" />
                    <tv:TableViewTextColumn x:Uid="ColumnTotalSize" Header="Total size" Width="95" Visibility="Collapsed" Binding="{Binding TotalSize}" />
                    <tv:TableViewTemplateColumn x:Uid="ColumnProgress" Header="Progress" Width="130">
                        <tv:TableViewTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid
                                    Margin="6,4"
                                    MinWidth="104"
                                    Height="22"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Grid.Clip>
                                        <RectangleGeometry Rect="0,0,400,22" />
                                    </Grid.Clip>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding ProgressValue, Converter={StaticResource ProgressGridLengthConverter}}" />
                                            <ColumnDefinition Width="{Binding ProgressValue, Converter={StaticResource ProgressGridLengthConverter}, ConverterParameter=remaining}" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            Opacity="0.85" />
                                        <Border
                                            Grid.Column="1"
                                            Background="Transparent" />
                                    </Grid>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{Binding Progress}" />
                                </Grid>
                            </DataTemplate>
                        </tv:TableViewTemplateColumn.CellTemplate>
                    </tv:TableViewTemplateColumn>
                    <tv:TableViewTextColumn x:Uid="ColumnStatus" Header="Status" Width="120" Binding="{Binding Status}" />
                    <tv:TableViewTextColumn x:Uid="ColumnSeeds" Header="Seeds" Width="78" Binding="{Binding Seeds}" />
                    <tv:TableViewTextColumn x:Uid="ColumnPeers" Header="Peers" Width="78" Binding="{Binding Peers}" />
                    <tv:TableViewTextColumn x:Uid="ColumnDownSpeed" Header="Down speed" Width="105" Binding="{Binding DownloadSpeed}" />
                    <tv:TableViewTextColumn x:Uid="ColumnUpSpeed" Header="Up speed" Width="105" Binding="{Binding UploadSpeed}" />
                    <tv:TableViewTextColumn x:Uid="ColumnEta" Header="ETA" Width="90" Binding="{Binding Eta}" />
                    <tv:TableViewTextColumn x:Uid="ColumnRatio" Header="Ratio" Width="70" Binding="{Binding Ratio}" />
                    <tv:TableViewTextColumn x:Uid="ColumnPopularity" Header="Popularity" Width="82" Visibility="Collapsed" Binding="{Binding Popularity}" />
                    <tv:TableViewTextColumn x:Uid="ColumnCategory" Header="Category" Width="110" Binding="{Binding Category}" />
                    <tv:TableViewTextColumn x:Uid="ColumnTags" Header="Tags" Width="120" Binding="{Binding Tags}" />
                    <tv:TableViewTextColumn x:Uid="ColumnAddedOn" Header="Added on" Width="145" Binding="{Binding AddedOn}" />
                    <tv:TableViewTextColumn x:Uid="ColumnCompletedOn" Header="Completed on" Width="145" Visibility="Collapsed" Binding="{Binding CompletedOn}" />
                    <tv:TableViewTextColumn x:Uid="ColumnTracker" Header="Tracker" Width="160" Visibility="Collapsed" Binding="{Binding Tracker}" />
                    <tv:TableViewTextColumn x:Uid="ColumnDownLimit" Header="Down limit" Width="100" Visibility="Collapsed" Binding="{Binding DownloadLimit}" />
                    <tv:TableViewTextColumn x:Uid="ColumnUpLimit" Header="Up limit" Width="100" Visibility="Collapsed" Binding="{Binding UploadLimit}" />
                    <tv:TableViewTextColumn x:Uid="ColumnDownloaded" Header="Downloaded" Width="100" Visibility="Collapsed" Binding="{Binding Downloaded}" />
                    <tv:TableViewTextColumn x:Uid="ColumnUploaded" Header="Uploaded" Width="100" Visibility="Collapsed" Binding="{Binding Uploaded}" />
                    <tv:TableViewTextColumn x:Uid="ColumnDownloadedSession" Header="Downloaded session" Width="130" Visibility="Collapsed" Binding="{Binding DownloadedSession}" />
                    <tv:TableViewTextColumn x:Uid="ColumnUploadedSession" Header="Uploaded session" Width="130" Visibility="Collapsed" Binding="{Binding UploadedSession}" />
                    <tv:TableViewTextColumn x:Uid="ColumnAmountLeft" Header="Amount left" Width="100" Visibility="Collapsed" Binding="{Binding AmountLeft}" />
                    <tv:TableViewTextColumn x:Uid="ColumnTimeActive" Header="Time active" Width="110" Visibility="Collapsed" Binding="{Binding TimeActive}" />
                    <tv:TableViewTextColumn x:Uid="ColumnSavePath" Header="Save path" Width="220" Visibility="Collapsed" Binding="{Binding SavePath}" />
                    <tv:TableViewTextColumn x:Uid="ColumnCompleted" Header="Completed" Width="100" Visibility="Collapsed" Binding="{Binding Completed}" />
                    <tv:TableViewTextColumn x:Uid="ColumnRatioLimit" Header="Ratio limit" Width="90" Visibility="Collapsed" Binding="{Binding RatioLimit}" />
                    <tv:TableViewTextColumn x:Uid="ColumnSeenComplete" Header="Last seen complete" Width="145" Visibility="Collapsed" Binding="{Binding SeenComplete}" />
                    <tv:TableViewTextColumn x:Uid="ColumnLastActivity" Header="Last activity" Width="145" Visibility="Collapsed" Binding="{Binding LastActivity}" />
                    <tv:TableViewTextColumn x:Uid="ColumnAvailability" Header="Availability" Width="90" Visibility="Collapsed" Binding="{Binding Availability}" />
                    <tv:TableViewTextColumn x:Uid="ColumnDownloadPath" Header="Download path" Width="220" Visibility="Collapsed" Binding="{Binding DownloadPath}" />
                    <tv:TableViewTextColumn x:Uid="ColumnInfoHashV1" Header="Info hash v1" Width="290" Visibility="Collapsed" Binding="{Binding InfoHashV1}" />
                    <tv:TableViewTextColumn x:Uid="ColumnInfoHashV2" Header="Info hash v2" Width="420" Visibility="Collapsed" Binding="{Binding InfoHashV2}" />
                    <tv:TableViewTextColumn x:Uid="ColumnReannounce" Header="Reannounce" Width="100" Visibility="Collapsed" Binding="{Binding Reannounce}" />
                    <tv:TableViewTextColumn x:Uid="ColumnPrivate" Header="Private" Width="70" Visibility="Collapsed" Binding="{Binding Private}" />
                    <tv:TableViewTextColumn x:Uid="ColumnCreatedOn" Header="Created on" Width="145" Visibility="Collapsed" Binding="{Binding CreatedOn}" />
                </tv:TableView.Columns>
            </tv:TableView>

            <!-- Rubber-band (marquee) selection overlay. Stays hit-test invisible so it never
                 steals clicks from the table; the code-behind drives it from pointer handlers
                 attached to the table itself. -->
            <Canvas x:Name="SelectionOverlay" Grid.Row="0" IsHitTestVisible="False">
                <Border
                    x:Name="SelectionRectangle"
                    Background="{ThemeResource AccentFillColorSelectedTextBackgroundBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1"
                    Opacity="0.35"
                    Visibility="Collapsed" />
            </Canvas>

            <Thumb x:Name="DetailsSplitter" Grid.Row="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" DragDelta="DetailsSplitter_DragDelta" />

            <TabView x:Name="DetailsTabs" Grid.Row="2" IsAddTabButtonVisible="False" TabWidthMode="SizeToContent">
                <TabViewItem x:Uid="DetailsGeneral" Header="General" IsClosable="False" IconSource="{StaticResource DetailsGeneralIcon}">
                    <ScrollViewer Padding="12,8">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock x:Uid="DetailsProgress" FontWeight="SemiBold" Text="Progress" />
                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Height="18" Margin="0,6,0,0" Maximum="100" Value="{Binding SelectedTorrent.ProgressValue}" />
                                <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding SelectedTorrent.Progress}" />
                            </Grid>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock x:Uid="DetailsAvailability" FontWeight="SemiBold" Text="Availability" />
                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Height="10" Margin="0,6,0,0" Maximum="100" Value="{Binding SelectedTorrent.AvailabilityValue}" />
                                <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding SelectedTorrent.Availability}" />
                            </Grid>
                            <Grid ColumnSpacing="24" RowSpacing="6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock x:Uid="DetailsTimeActive" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Time active" /><TextBlock Grid.Column="1" Text="{Binding SelectedTorrent.TimeActive}" />
                                <TextBlock x:Uid="DetailsEta" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="ETA" /><TextBlock Grid.Column="3" Text="{Binding SelectedTorrent.Eta}" />
                                <TextBlock x:Uid="DetailsDownloaded" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Downloaded" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTorrent.Downloaded}" />
                                <TextBlock x:Uid="DetailsUploaded" Grid.Row="1" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Uploaded" /><TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedTorrent.Uploaded}" />
                                <TextBlock x:Uid="DetailsDownSpeed" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Download speed" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedTorrent.DownloadSpeed}" />
                                <TextBlock x:Uid="DetailsUpSpeed" Grid.Row="2" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Upload speed" /><TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SelectedTorrent.UploadSpeed}" />
                                <TextBlock x:Uid="DetailsRatio" Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ratio" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedTorrent.Ratio}" />
                                <TextBlock x:Uid="DetailsSavePath" Grid.Row="3" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Save path" /><TextBlock Grid.Row="3" Grid.Column="3" TextTrimming="CharacterEllipsis" Text="{Binding SelectedTorrent.SavePath}" />
                                <TextBlock x:Uid="DetailsInfoHash" Grid.Row="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Info hash v1" /><TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" FontFamily="Consolas" Text="{Binding SelectedTorrent.InfoHashV1}" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>
                <TabViewItem x:Uid="DetailsTrackers" Header="Trackers" IsClosable="False" IconSource="{StaticResource DetailsTrackersIcon}">
                    <ListView x:Name="TrackersList" ItemsSource="{Binding SelectedTrackers}" SelectionMode="Extended">
                        <ListView.ContextFlyout><MenuFlyout><MenuFlyoutItem x:Uid="RemoveSelectedTrackers" Text="Remove selected trackers" Click="RemoveTrackers_Click" /></MenuFlyout></ListView.ContextFlyout>
                        <ListView.Header>
                            <Grid Padding="8,5" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="90" /><ColumnDefinition Width="70" /><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock x:Uid="DetailHeaderUrl" FontWeight="SemiBold" Text="URL" /><TextBlock x:Uid="DetailHeaderStatus" Grid.Column="1" FontWeight="SemiBold" Text="Status" /><TextBlock x:Uid="DetailHeaderSeeds" Grid.Column="2" FontWeight="SemiBold" Text="Seeds" /><TextBlock x:Uid="DetailHeaderPeers" Grid.Column="3" FontWeight="SemiBold" Text="Peers" /><TextBlock x:Uid="DetailHeaderMessage" Grid.Column="4" FontWeight="SemiBold" Text="Message" /></Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="8,4" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="90" /><ColumnDefinition Width="70" /><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock TextTrimming="CharacterEllipsis" Text="{Binding Url}" /><TextBlock Grid.Column="1" Text="{Binding Status}" /><TextBlock Grid.Column="2" Text="{Binding Seeds}" /><TextBlock Grid.Column="3" Text="{Binding Leeches}" /><TextBlock Grid.Column="4" TextTrimming="CharacterEllipsis" Text="{Binding Message}" /></Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem x:Uid="DetailsPeers" Header="Peers" IsClosable="False" IconSource="{StaticResource DetailsPeersIcon}">
                    <ListView x:Name="PeersList" Style="{StaticResource PollingListViewStyle}" ItemsSource="{Binding SelectedPeers}" SelectionMode="Extended">
                        <ListView.ContextFlyout><MenuFlyout><MenuFlyoutItem x:Uid="BanSelectedPeers" Text="Ban selected peers" Click="BanPeers_Click" /></MenuFlyout></ListView.ContextFlyout>
                        <ListView.Header><Grid Padding="8,5" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="90" /><ColumnDefinition Width="2*" /><ColumnDefinition Width="65" /><ColumnDefinition Width="90" /><ColumnDefinition Width="95" /><ColumnDefinition Width="95" /></Grid.ColumnDefinitions><TextBlock x:Uid="DetailHeaderIpPort" FontWeight="SemiBold" Text="IP / Port" /><TextBlock x:Uid="DetailHeaderCountry" Grid.Column="1" FontWeight="SemiBold" Text="Country" /><TextBlock x:Uid="DetailHeaderClient" Grid.Column="2" FontWeight="SemiBold" Text="Client" /><TextBlock x:Uid="DetailHeaderFlags" Grid.Column="3" FontWeight="SemiBold" Text="Flags" /><TextBlock x:Uid="DetailsProgress" Grid.Column="4" FontWeight="SemiBold" Text="Progress" /><TextBlock x:Uid="DetailsDownSpeed" Grid.Column="5" FontWeight="SemiBold" Text="Down speed" /><TextBlock x:Uid="DetailsUpSpeed" Grid.Column="6" FontWeight="SemiBold" Text="Up speed" /></Grid></ListView.Header>
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="8,4" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="90" /><ColumnDefinition Width="2*" /><ColumnDefinition Width="65" /><ColumnDefinition Width="90" /><ColumnDefinition Width="95" /><ColumnDefinition Width="95" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Address}" /><Image Grid.Column="1" Width="24" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center" Stretch="Uniform" Source="{Binding CountryFlagUri}" ToolTipService.ToolTip="{Binding CountryName}" /><TextBlock Grid.Column="2" TextTrimming="CharacterEllipsis" Text="{Binding Client}" /><TextBlock Grid.Column="3" Text="{Binding Flags}" /><TextBlock Grid.Column="4" Text="{Binding Progress}" /><TextBlock Grid.Column="5" Text="{Binding DownloadSpeed}" /><TextBlock Grid.Column="6" Text="{Binding UploadSpeed}" /></Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem x:Uid="DetailsHttpSources" Header="HTTP Sources" IsClosable="False" IconSource="{StaticResource DetailsHttpSourcesIcon}">
                    <ListView x:Name="WebSeedsList" ItemsSource="{Binding SelectedWebSeeds}" SelectionMode="Extended"><ListView.ContextFlyout><MenuFlyout><MenuFlyoutItem x:Uid="RemoveSelectedWebSeeds" Text="Remove selected web seeds" Click="RemoveWebSeeds_Click" /></MenuFlyout></ListView.ContextFlyout><ListView.ItemTemplate><DataTemplate><TextBlock Padding="8,4" Text="{Binding}" /></DataTemplate></ListView.ItemTemplate></ListView>
                </TabViewItem>
                <TabViewItem x:Uid="DetailsContent" x:Name="FilesTab" Header="Files" IsClosable="False" IconSource="{StaticResource DetailsFilesIcon}">
                    <Grid RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Padding="6,5" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>
                            <Button x:Uid="CommonSelectAll" Content="Select all" Click="FilesSelectAll_Click" />
                            <Button x:Uid="CommonSelectNone" Grid.Column="1" Content="Select none" Click="FilesSelectNone_Click" />
                            <Button x:Uid="FilesExpandAll" Grid.Column="2" Content="Expand all" Click="FilesExpandAll_Click" />
                            <Button x:Uid="FilesCollapseAll" Grid.Column="3" Content="Collapse all" Click="FilesCollapseAll_Click" />
                            <DropDownButton x:Uid="FilesPriority" Grid.Column="4" Content="Priority">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="FilePrioritySkip" Text="Do not download" Tag="0" Click="SelectedFilesPriority_Click" />
                                        <MenuFlyoutItem x:Uid="FilePriorityNormal" Text="Normal priority" Tag="1" Click="SelectedFilesPriority_Click" />
                                        <MenuFlyoutItem x:Uid="FilePriorityHigh" Text="High priority" Tag="6" Click="SelectedFilesPriority_Click" />
                                        <MenuFlyoutItem x:Uid="FilePriorityMaximum" Text="Maximum priority" Tag="7" Click="SelectedFilesPriority_Click" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <Button x:Uid="CommonRefresh" Grid.Column="5" Content="Refresh" Click="FilesRefresh_Click" />
                            <TextBox
                                x:Uid="AddTorrentFilesFilter"
                                x:Name="ContentFilesFilterBox"
                                Grid.Column="7"
                                PlaceholderText="Filter files…"
                                TextChanged="ContentFilesFilter_TextChanged" />
                        </Grid>

                        <InfoBar
                            x:Name="FilesInfoBar"
                            Grid.Row="1"
                            Margin="6,0"
                            IsClosable="True"
                            IsOpen="False" />

                        <Grid Grid.Row="2" MinWidth="840" Padding="28,3,8,5" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" MinWidth="260" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="DetailHeaderName" Grid.Column="1" FontWeight="SemiBold" Text="Name" />
                            <TextBlock x:Uid="DetailHeaderSize" Grid.Column="2" HorizontalAlignment="Right" FontWeight="SemiBold" Text="Size" />
                            <TextBlock x:Uid="DetailsProgress" Grid.Column="3" FontWeight="SemiBold" Text="Progress" />
                            <TextBlock x:Uid="FilesRemaining" Grid.Column="4" HorizontalAlignment="Right" FontWeight="SemiBold" Text="Remaining" />
                            <TextBlock x:Uid="FilesAvailability" Grid.Column="5" HorizontalAlignment="Right" FontWeight="SemiBold" Text="Availability" />
                            <TextBlock x:Uid="DetailHeaderPriority" Grid.Column="6" FontWeight="SemiBold" Text="Priority" />
                        </Grid>

                        <TreeView
                            x:Name="ContentFilesTree"
                            Grid.Row="3"
                            HorizontalContentAlignment="Stretch"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            SelectionMode="Single">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="36" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:TorrentFileTreeNode">
                                    <TreeViewItem
                                        HorizontalContentAlignment="Stretch"
                                        IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                        ItemsSource="{x:Bind Children}">
                                        <Grid
                                            MinWidth="840"
                                            MinHeight="36"
                                            Padding="4,2,8,2"
                                            ColumnSpacing="12"
                                            Background="Transparent"
                                            DoubleTapped="ContentFileRow_DoubleTapped"
                                            RightTapped="ContentFileRow_RightTapped">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem x:Uid="FilesOpen" Text="Open" Tag="{Binding}" Click="OpenContentNode_Click" />
                                                    <MenuFlyoutItem x:Uid="FilesOpenDestination" Text="Open destination folder" Tag="{Binding}" Click="OpenContentNodeDestination_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem x:Uid="FilePrioritySkip" CommandParameter="0" Tag="{Binding}" Text="Do not download" Click="ContextFilePriority_Click" />
                                                    <MenuFlyoutItem x:Uid="FilePriorityNormal" CommandParameter="1" Tag="{Binding}" Text="Normal priority" Click="ContextFilePriority_Click" />
                                                    <MenuFlyoutItem x:Uid="FilePriorityHigh" CommandParameter="6" Tag="{Binding}" Text="High priority" Click="ContextFilePriority_Click" />
                                                    <MenuFlyoutItem x:Uid="FilePriorityMaximum" CommandParameter="7" Tag="{Binding}" Text="Maximum priority" Click="ContextFilePriority_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" MinWidth="260" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="150" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox
                                                Width="20"
                                                Height="20"
                                                MinWidth="20"
                                                MinHeight="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{x:Bind IsChecked, Mode=OneWay}"
                                                IsThreeState="{x:Bind IsFolder}"
                                                Tag="{Binding}"
                                                Click="ContentFileCheckBox_Click" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                                <FontIcon
                                                    FontSize="15"
                                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                    Glyph="{x:Bind IconGlyph}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontWeight="{x:Bind FontWeight}"
                                                    Text="{x:Bind Name}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTipService.ToolTip="{x:Bind FullPath}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind SizeText}" />
                                            <Grid
                                                Grid.Column="3"
                                                Height="22"
                                                Margin="0,4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{x:Bind ProgressValue, Converter={StaticResource ProgressGridLengthConverter}}" />
                                                    <ColumnDefinition Width="{x:Bind ProgressValue, Converter={StaticResource ProgressGridLengthConverter}, ConverterParameter=remaining}" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="3" Opacity="0.82" />
                                                <Border Grid.ColumnSpan="2" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="3" />
                                                <TextBlock
                                                    Grid.ColumnSpan="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Text="{x:Bind ProgressText}" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind RemainingText}" />
                                            <TextBlock
                                                Grid.Column="5"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind AvailabilityText}" />
                                            <ComboBox
                                                Grid.Column="6"
                                                MinWidth="132"
                                                VerticalAlignment="Center"
                                                PlaceholderText="{x:Bind MixedPriorityText}"
                                                SelectedIndex="{x:Bind PriorityIndex, Mode=OneWay}"
                                                Tag="{Binding}"
                                                DropDownClosed="FilePriorityCombo_DropDownClosed">
                                                <ComboBoxItem x:Uid="AddTorrentPriorityDoNotDownload" Content="Do not download" />
                                                <ComboBoxItem x:Uid="AddTorrentPriorityNormal" Content="Normal" />
                                                <ComboBoxItem x:Uid="AddTorrentPriorityHigh" Content="High" />
                                                <ComboBoxItem x:Uid="AddTorrentPriorityMaximum" Content="Maximum" />
                                            </ComboBox>
                                        </Grid>
                                    </TreeViewItem>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </TabViewItem>
                <TabViewItem x:Uid="DetailsSpeed" Header="Speed" IsClosable="False" IconSource="{StaticResource DetailsSpeedIcon}">
                    <controls:SpeedGraphControl DownloadSpeed="{Binding SelectedTorrent.Model.DownloadSpeed}" UploadSpeed="{Binding SelectedTorrent.Model.UploadSpeed}" />
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</UserControl>
