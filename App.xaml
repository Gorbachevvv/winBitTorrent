<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WinBitTorrent.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinBitTorrent"
    xmlns:converters="using:WinBitTorrent.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NonEmptyStringConverter x:Key="NonEmptyStringConverter" />
            <converters:ConnectionBrushConverter x:Key="ConnectionBrushConverter" />
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:ProgressGridLengthConverter x:Key="ProgressGridLengthConverter" />

            <FontIconSource x:Key="TransfersIcon" Glyph="&#xE896;" />
            <FontIconSource x:Key="RssIcon" Glyph="&#xE789;" />
            <FontIconSource x:Key="SearchIcon" Glyph="&#xE721;" />
            <FontIconSource x:Key="TrackerIcon" Glyph="&#xE774;" />
            <FontIconSource x:Key="LogIcon" Glyph="&#xE9D9;" />

            <FontIconSource x:Key="DetailsGeneralIcon" Glyph="&#xE946;" />
            <FontIconSource x:Key="DetailsTrackersIcon" Glyph="&#xE774;" />
            <FontIconSource x:Key="DetailsPeersIcon" Glyph="&#xE716;" />
            <FontIconSource x:Key="DetailsHttpSourcesIcon" Glyph="&#xE71B;" />
            <FontIconSource x:Key="DetailsFilesIcon" Glyph="&#xE8B7;" />
            <FontIconSource x:Key="DetailsSpeedIcon" Glyph="&#xE9E9;" />

            <Style x:Key="CompactToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="36" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Padding" Value="8,4" />
            </Style>

            <Style x:Key="SidebarListViewStyle" TargetType="ListView">
                <Setter Property="SelectionMode" Value="Single" />
                <Setter Property="IsItemClickEnabled" Value="True" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="ItemContainerTransitions">
                    <Setter.Value>
                        <TransitionCollection />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PollingListViewStyle" TargetType="ListView">
                <Setter Property="ItemContainerTransitions">
                    <Setter.Value>
                        <TransitionCollection />
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
