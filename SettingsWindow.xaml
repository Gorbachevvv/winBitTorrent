<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinBitTorrent.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Options">
    <Grid x:Name="Root">
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <NavigationView x:Name="Sections" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" IsPaneToggleButtonVisible="False" PaneDisplayMode="Left" IsPaneOpen="True" OpenPaneLength="210" SelectionChanged="Sections_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="SettingsBehavior" Content="Behavior" Tag="Behavior"><NavigationViewItem.Icon><FontIcon Glyph="&#xE8B0;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsDownloads" Content="Downloads" Tag="Downloads"><NavigationViewItem.Icon><FontIcon Glyph="&#xE896;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsConnection" Content="Connection" Tag="Connection"><NavigationViewItem.Icon><FontIcon Glyph="&#xE774;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsSpeed" Content="Speed" Tag="Speed"><NavigationViewItem.Icon><FontIcon Glyph="&#xE945;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsBitTorrent" Content="BitTorrent" Tag="BitTorrent"><NavigationViewItem.Icon><FontIcon Glyph="&#xE968;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsSearch" Content="Search" Tag="Search"><NavigationViewItem.Icon><FontIcon Glyph="&#xE721;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsRss" Content="RSS" Tag="RSS"><NavigationViewItem.Icon><FontIcon Glyph="&#xE95A;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsWebUi" Content="Web UI" Tag="WebUI"><NavigationViewItem.Icon><FontIcon Glyph="&#xE774;" /></NavigationViewItem.Icon></NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsAdvanced" Content="Advanced" Tag="Advanced"><NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon></NavigationViewItem>
            </NavigationView.MenuItems>
            <ScrollViewer Padding="22,18,28,24"><StackPanel x:Name="SettingsPanel" MaxWidth="780" HorizontalAlignment="Stretch" Spacing="14"><TextBlock x:Name="SectionTitle" Style="{StaticResource TitleTextBlockStyle}" /><InfoBar x:Name="MessageBar" IsClosable="True" IsOpen="False" /></StackPanel></ScrollViewer>
        </NavigationView>
        <StackPanel Grid.Row="1" Padding="12" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8"><Button x:Uid="CommonCancel" Content="Cancel" Click="Cancel_Click" /><Button x:Uid="CommonApply" x:Name="SaveButton" Content="Apply" Style="{StaticResource AccentButtonStyle}" Click="Save_Click" /></StackPanel>
    </Grid>
</Window>
