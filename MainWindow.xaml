<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinBitTorrent.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:WinBitTorrent.Views"
    Title="WinBitTorrent">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        DragLeave="RootGrid_DragLeave"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="34" />
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarDragRegion" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image
                Width="18"
                Height="18"
                Margin="12,0,10,0"
                Source="ms-appx:///Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="WinBitTorrent" />
            <StackPanel Grid.Column="2" Margin="0,0,138,0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{Binding IsConnected, Converter={StaticResource ConnectionBrushConverter}}" />
                <TextBlock VerticalAlignment="Center" Text="{Binding ConnectionStatus}" />
            </StackPanel>
        </Grid>

        <MenuBar Grid.Row="1" Padding="4,0">
            <MenuBarItem x:Uid="FileMenu" Title="File">
                <MenuFlyoutItem x:Uid="AddTorrentFile" Text="Add Torrent File…" Icon="OpenFile" Click="AddTorrentFile_Click" KeyboardAcceleratorTextOverride="Ctrl+O" />
                <MenuFlyoutItem x:Uid="AddTorrentLink" Text="Add Torrent Link…" Icon="Link" Click="AddTorrentLink_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Uid="CreateTorrent" Text="Create Torrent…" Icon="Add" Click="CreateTorrent_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Uid="Exit" Text="Exit" Icon="Cancel" Click="Exit_Click" />
            </MenuBarItem>
            <MenuBarItem x:Uid="EditMenu" Title="Edit">
                <MenuFlyoutItem x:Uid="Start" Text="Start" Icon="Play" Command="{Binding StartSelectedCommand}" />
                <MenuFlyoutItem x:Uid="Stop" Text="Stop" Icon="Stop" Command="{Binding StopSelectedCommand}" />
                <MenuFlyoutItem x:Uid="Delete" Text="Delete…" Icon="Delete" Click="Delete_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Uid="ForceRecheck" Text="Force recheck" Command="{Binding RecheckSelectedCommand}" />
                <MenuFlyoutItem x:Uid="Reannounce" Text="Reannounce" Command="{Binding ReannounceSelectedCommand}" />
            </MenuBarItem>
            <MenuBarItem x:Uid="ViewMenu" Title="View">
                <ToggleMenuFlyoutItem x:Uid="AlternativeSpeedLimits" Text="Alternative speed limits" IsChecked="{Binding UseAlternativeSpeedLimits, Mode=OneWay}" Click="AlternativeSpeed_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Uid="TransfersMenu" Text="Transfers" Tag="0" Click="NavigateMenu_Click" />
                <MenuFlyoutItem x:Uid="RssMenu" Text="RSS Reader" Tag="1" Click="NavigateMenu_Click" />
                <MenuFlyoutItem x:Uid="SearchMenu" Text="Search Engine" Tag="2" Click="NavigateMenu_Click" />
                <MenuFlyoutItem x:Uid="TrackersMenu" Text="Tracker Search" Tag="3" Click="NavigateMenu_Click" />
                <MenuFlyoutItem x:Uid="LogMenu" Text="Execution Log" Tag="4" Click="NavigateMenu_Click" />
            </MenuBarItem>
            <MenuBarItem x:Uid="ToolsMenu" Title="Tools">
                <MenuFlyoutItem x:Uid="ServerProfiles" Text="Server profiles…" Icon="World" Click="Profiles_Click" />
                <MenuFlyoutItem x:Uid="Options" Text="Options…" Icon="Setting" Click="Options_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Uid="CookiesMenu" Text="Cookies…" Click="Cookies_Click" />
                <MenuFlyoutItem x:Uid="StatisticsMenu" Text="Statistics…" Click="Statistics_Click" />
            </MenuBarItem>
            <MenuBarItem x:Uid="HelpMenu" Title="Help">
                <MenuFlyoutItem x:Uid="DocumentationMenu" Text="qBittorrent documentation" Icon="Help" Click="Documentation_Click" />
                <MenuFlyoutItem x:Uid="AboutMenu" Text="About WinBitTorrent" Icon="Help" Click="About_Click" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="2" Padding="8,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>
            <CommandBar Background="Transparent" DefaultLabelPosition="Collapsed" IsOpen="False">
                <AppBarButton x:Uid="ToolbarAddTorrent" Icon="OpenFile" Label="Add torrent" Click="AddTorrentFile_Click" />
                <AppBarButton x:Uid="ToolbarAddLink" Icon="Link" Label="Add link" Click="AddTorrentLink_Click" />
                <AppBarSeparator />
                <AppBarButton x:Uid="ToolbarStart" Icon="Play" Label="Start" Command="{Binding StartSelectedCommand}" />
                <AppBarButton x:Uid="ToolbarStop" Icon="Stop" Label="Stop" Command="{Binding StopSelectedCommand}" />
                <AppBarButton x:Uid="ToolbarDelete" Icon="Delete" Label="Delete" Click="Delete_Click" />
                <AppBarSeparator />
                <AppBarButton x:Uid="ToolbarQueueUp" Label="Queue up" Command="{Binding MoveUpSelectedCommand}"><AppBarButton.Icon><FontIcon Glyph="&#xE74A;" /></AppBarButton.Icon></AppBarButton>
                <AppBarButton x:Uid="ToolbarQueueDown" Label="Queue down" Command="{Binding MoveDownSelectedCommand}"><AppBarButton.Icon><FontIcon Glyph="&#xE74B;" /></AppBarButton.Icon></AppBarButton>
                <AppBarSeparator />
                <AppBarToggleButton x:Uid="ToolbarAlternativeLimits" Icon="Switch" Label="Alternative limits" IsChecked="{Binding UseAlternativeSpeedLimits, Mode=OneWay}" Click="AlternativeSpeed_Click" />
            </CommandBar>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE721;" />
                <TextBox x:Uid="FilterTorrents" Width="240" PlaceholderText="Filter torrents" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <InfoBar
            Grid.Row="3"
            Margin="8,6,8,0"
            IsOpen="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringConverter}}"
            IsClosable="True"
            Severity="Error"
            Title="qBittorrent"
            Message="{Binding ErrorMessage}">
            <InfoBar.ActionButton>
                <Button x:Uid="RetryButton" Content="Retry" Command="{Binding ConnectSelectedProfileCommand}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <TabView
            x:Name="WorkspaceTabs"
            Grid.Row="4"
            Margin="4,4,4,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsAddTabButtonVisible="False"
            TabCloseRequested="WorkspaceTabs_TabCloseRequested">
            <TabViewItem x:Uid="TransfersTab" Tag="0" Header="Transfers" IconSource="{StaticResource TransfersIcon}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <views:TransfersView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </TabViewItem>
            <TabViewItem x:Uid="RssTab" Tag="1" Header="RSS Reader" IconSource="{StaticResource RssIcon}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <views:RssView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </TabViewItem>
            <TabViewItem x:Uid="SearchTab" Tag="2" Header="Search" IconSource="{StaticResource SearchIcon}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <views:SearchView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </TabViewItem>
            <TabViewItem x:Uid="TrackersTab" Tag="3" Header="Trackers" IconSource="{StaticResource TrackerIcon}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <views:TrackerSearchView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </TabViewItem>
            <TabViewItem x:Uid="LogTab" Tag="4" Header="Execution Log" IconSource="{StaticResource LogIcon}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <views:LogsView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </TabViewItem>
        </TabView>

        <Border Grid.Row="5" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid Padding="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon FontSize="12" Glyph="&#xE774;" />
                    <TextBlock Text="{Binding ConnectionStatus}" />
                </StackPanel>
                <TextBlock Grid.Column="1" Margin="16,0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ConnectionDetails}" />
                <TextBlock Grid.Column="2" Margin="8,0" VerticalAlignment="Center" Text="{Binding DhtNodes}" />
                <TextBlock Grid.Column="3" Margin="8,0" VerticalAlignment="Center" Text="{Binding FreeSpace}" />
                <StackPanel Grid.Column="4" Margin="10,0" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <FontIcon FontSize="12" Glyph="&#xE896;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="{Binding DownloadSpeed}" />
                </StackPanel>
                <StackPanel Grid.Column="5" Margin="10,0" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <FontIcon FontSize="12" Glyph="&#xE898;" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                    <TextBlock Text="{Binding UploadSpeed}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            x:Name="TorrentDropOverlay"
            Grid.RowSpan="6"
            Margin="16"
            Padding="24"
            Canvas.ZIndex="100"
            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="12"
            IsHitTestVisible="False"
            Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="42"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="&#xE898;" />
                <TextBlock x:Uid="TorrentDropText"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Drop .torrent files to add them" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
