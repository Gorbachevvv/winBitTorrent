<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinBitTorrent.ProfilesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Server profiles">
    <Grid x:Name="Root" Padding="18" ColumnSpacing="14">
        <Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <TextBlock x:Uid="ProfilesTitle" Margin="14,12,10,8" FontSize="18" FontWeight="SemiBold" Text="Profiles" />
                <ListView x:Name="ProfilesList" Grid.Row="1" DisplayMemberPath="Name" SelectionChanged="ProfilesList_SelectionChanged" />
                <StackPanel Grid.Row="2" Margin="10" Orientation="Horizontal" Spacing="8"><Button x:Uid="CommonNew" Content="New" Click="New_Click" /><Button x:Uid="CommonDelete" x:Name="DeleteButton" Content="Delete" Click="Delete_Click" /></StackPanel>
            </Grid>
        </Border>
        <ScrollViewer Grid.Column="1">
            <StackPanel x:Name="Editor" Spacing="12">
                <TextBlock x:Uid="ProfileConnection" Style="{StaticResource TitleTextBlockStyle}" Text="Connection" />
                <InfoBar x:Name="MessageBar" IsClosable="True" IsOpen="False" />
                <TextBox x:Uid="ProfileName" x:Name="NameBox" Header="Profile name" />
                <TextBox x:Uid="ProfileAddress" x:Name="AddressBox" Header="Server address" PlaceholderText="https://server.example:8080/" />
                <ComboBox x:Uid="ProfileAuthentication" x:Name="AuthenticationBox" Header="Authentication" SelectionChanged="AuthenticationBox_SelectionChanged">
                    <ComboBoxItem x:Uid="ProfileUserPassword" Content="Username and password" />
                    <ComboBoxItem x:Uid="ProfileApiKey" Content="Bearer API key" />
                </ComboBox>
                <TextBox x:Uid="ProfileUsername" x:Name="UserNameBox" Header="Username" />
                <PasswordBox x:Uid="ProfileSecret" x:Name="SecretBox" Header="Password or API key" />
                <TextBox x:Uid="ProfileFingerprint" x:Name="FingerprintBox" Header="Pinned TLS certificate SHA-256 fingerprint (optional)" PlaceholderText="AA:BB:…" />
                <CheckBox x:Uid="ProfileTrustFingerprint" x:Name="FingerprintConfirmedBox" Content="I verified and explicitly trust this certificate fingerprint" />
                <InfoBar x:Uid="ProfileSecretsProtected" IsOpen="True" IsClosable="False" Severity="Informational" Title="Secrets are protected" Message="Passwords and API keys are saved in Windows Credential Manager, separately from profile JSON." />
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
            <Button x:Uid="CommonClose" Content="Close" Click="Close_Click" />
            <Button x:Uid="CommonSave" x:Name="SaveButton" Content="Save" Click="Save_Click" />
            <Button x:Uid="ProfileSaveConnect" x:Name="ConnectButton" Content="Save and connect" Style="{StaticResource AccentButtonStyle}" Click="Connect_Click" />
        </StackPanel>
    </Grid>
</Window>
